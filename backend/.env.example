PORT=3002
NODE_ENV=development
WHATSAPP_PROVIDER=runtime-http
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
LLM_REQUEST_TIMEOUT_MS=15000
BACKEND_DEFAULT_RESTAURANT_ID=
WHATSAPP_QR_TTL_SECONDS=120
INBOUND_MENU_COOLDOWN_SECONDS=90
BACKEND_ENABLE_INTERNAL_WHATSAPP_RUNTIME=false
BACKEND_ENABLE_EXTERNAL_WHATSAPP_RUNTIME=true
WHATSAPP_RUNTIME_BASE_URL=http://localhost:3001
WHATSAPP_RUNTIME_API_KEY=
WHATSAPP_RUNTIME_REQUEST_TIMEOUT_MS=15000
META_API_VERSION=v22.0
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
META_WABA_ID=
META_WEBHOOK_ENABLED=false
META_WEBHOOK_PATH=/webhooks/meta/whatsapp
META_VERIFY_TOKEN=
META_WEBHOOK_DEFAULT_RESTAURANT_ID=
FIREBASE_SERVICE_ACCOUNT_PATH=
OUTBOX_INLINE_SEND_ENABLED=true
OUTBOX_WORKER_ENABLED=false
OUTBOX_WORKER_POLL_MS=1500
OUTBOX_WORKER_BATCH_SIZE=5
OUTBOX_LEASE_MS=30000
OUTBOX_MAX_ATTEMPTS=5
OUTBOX_RETRY_BASE_MS=1000
OUTBOX_RETRY_MAX_MS=60000
RESTAURANT_HEALTH_MONITOR_ENABLED=true
RESTAURANT_HEALTH_MONITOR_INTERVAL_MS=300000
RESTAURANT_HEALTH_DEGRADE_CONSECUTIVE_CHECKS=2
RESTAURANT_HEALTH_RECOVERY_CONSECUTIVE_CHECKS=2
