PORT=3001
BOT_RUNTIME_MODE=single
BOT_SHARD_ID=wa-shard-default
BOT_SHARD_INDEX=0
BOT_SHARD_COUNT=1
BOT_MAX_TENANTS_PER_PROCESS=5
BOT_TENANTS_FILE=
BOT_RUNTIME_ADMIN_KEY=
BOT_RUNTIME_QR_TTL_MS=120000
BOT_RUNTIME_HEARTBEAT_MS=15000
BOT_RUNTIME_SEND_TIMEOUT_MS=12000
BOT_RUNTIME_OUTBOUND_INFLIGHT_TTL_MS=90000
BOT_RUNTIME_OUTBOUND_SENT_TTL_MS=86400000
BOT_RUNTIME_OUTBOUND_FAILED_TTL_MS=1800000
BOT_RUNTIME_RECONNECT_MAX_ATTEMPTS=20
BOT_RUNTIME_MIN_RESTART_GAP_MS=3000
BOT_MEMORY_LOG_INTERVAL_MS=30000
BOT_MEMORY_WARN_RSS_MB=420
BOT_MIN_RECOMMENDED_MEMORY_MB=1024
BOT_ENABLED=true
BOT_RESTAURANT_ID=
BACKEND_API_BASE_URL=http://localhost:3002
BACKEND_API_PREFIX=/api/v1
BACKEND_API_KEY=
BACKEND_RUNTIME_REGISTRY_ENABLED=true
BACKEND_RUNTIME_REGISTRY_PATH=/api/v1/runtime/tenants
BACKEND_RUNTIME_REGISTRY_KEY=
BACKEND_TENANT_SYNC_INTERVAL_MS=30000
WHATSAPP_CLIENT_ID=restaurant-bot
WHATSAPP_AUTH_DATA_PATH=.wwebjs_auth
PUPPETEER_PROTOCOL_TIMEOUT_MS=180000
PUPPETEER_HEADLESS=true
PUPPETEER_LOW_MEMORY_MODE=true
PUPPETEER_EXECUTABLE_PATH=
PUPPETEER_CACHE_DIR=.cache/puppeteer
PUPPETEER_EXTRA_ARGS=
