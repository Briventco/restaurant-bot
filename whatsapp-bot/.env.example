PUPPETEER_SKIP_DOWNLOAD=false
SEND_DELAY_MS=250
SEND_RETRY_ATTEMPTS=1
SEND_RETRY_BACKOFF_MS=800
INBOUND_DEDUPE_TTL_MS=300000
INBOUND_DEDUPE_MAX_ENTRIES=5000
OUTBOUND_DEDUPE_TTL_MS=300000
OUTBOUND_DEDUPE_MAX_ENTRIES=5000
BACKEND_REQUEST_TIMEOUT_MS=15000
BOT_IGNORE_GROUP_CHATS=true
BOT_PRINT_TERMINAL_QR=false
BOT_ALLOW_ALL_CHATS=false
BOT_ALLOWED_CHAT_IDS=
BOT_ALLOWED_PHONE_PREFIXES=
